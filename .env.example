# Helix — copy to .env and fill. NEVER commit .env.
# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Database (Supabase / Postgres) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- LLM providers (provider-abstracted; Claude primary) ---
LLM_PROVIDER=mock              # mock | anthropic | openai | gemini | openrouter
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# --- Payer adapters (mock until real rules confirmed — see brain/open-questions) ---
PAYER_MODE=mock                # mock | live  (NEVER live without confirmed rules + human sign-off)

# --- Security ---
AUTH_SECRET=                   # generate: openssl rand -base64 32
ENCRYPTION_KEY=                # 32-byte key for field-level encryption
